{
  "name": "techathon2026-formulaone",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:web\" \"npm run dev:bot\"",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:web": "npm run dev -w apps/web",
    "dev:bot": "npm run dev -w apps/bot"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
